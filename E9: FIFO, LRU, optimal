#include <stdio.h>

int main()
{
    int pages[] = {7, 0, 1, 2, 0, 3, 0, 4};
    int frames[3];
    int i, j, k, flag, faults = 0;

    for(i = 0; i < 3; i++)
        frames[i] = -1;

    printf("FIFO Page Replacement\n");
    int index = 0;

    for(i = 0; i < 8; i++)
    {
        flag = 0;

        for(j = 0; j < 3; j++)
        {
            if(frames[j] == pages[i])
            {
                flag = 1;
                break;
            }
        }

        if(flag == 0)
        {
            frames[index] = pages[i];
            index = (index + 1) % 3;
            faults++;
        }

        printf("Page %d -> ", pages[i]);
        for(j = 0; j < 3; j++)
            printf("%d ", frames[j]);
        printf("\n");
    }

    printf("Total Page Faults = %d\n\n", faults);

    printf("LRU Page Replacement\n");
    faults = 0;
    int time[3], counter = 0;

    for(i = 0; i < 3; i++)
    {
        frames[i] = -1;
        time[i] = 0;
    }

    for(i = 0; i < 8; i++)
    {
        flag = 0;

        for(j = 0; j < 3; j++)
        {
            if(frames[j] == pages[i])
            {
                counter++;
                time[j] = counter;
                flag = 1;
                break;
            }
        }

        if(flag == 0)
        {
            int min = 0;
            for(j = 1; j < 3; j++)
                if(time[j] < time[min])
                    min = j;

            frames[min] = pages[i];
            counter++;
            time[min] = counter;
            faults++;
        }

        printf("Page %d -> ", pages[i]);
        for(j = 0; j < 3; j++)
            printf("%d ", frames[j]);
        printf("\n");
    }

    printf("Total Page Faults = %d\n\n", faults);

    printf("Optimal Page Replacement\n");
    faults = 0;

    for(i = 0; i < 3; i++)
        frames[i] = -1;

    for(i = 0; i < 8; i++)
    {
        flag = 0;

        for(j = 0; j < 3; j++)
        {
            if(frames[j] == pages[i])
            {
                flag = 1;
                break;
            }
        }

        if(flag == 0)
        {
            int pos = -1, farthest = i;

            for(j = 0; j < 3; j++)
            {
                int found = 0;

                for(k = i + 1; k < 8; k++)
                {
                    if(frames[j] == pages[k])
                    {
                        if(k > farthest)
                        {
                            farthest = k;
                            pos = j;
                        }
                        found = 1;
                        break;
                    }
                }

                if(!found)
                {
                    pos = j;
                    break;
                }
            }

            if(pos == -1)
                pos = 0;

            frames[pos] = pages[i];
            faults++;
        }

        printf("Page %d -> ", pages[i]);
        for(j = 0; j < 3; j++)
            printf("%d ", frames[j]);
        printf("\n");
    }

    printf("Total Page Faults = %d\n", faults);

    return 0;
}

